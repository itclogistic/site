# Public URL of the deployed site (used in sitemap.xml, robots.txt,
# Open Graph tags, and the office pages' structured data).
# Falls back to https://www.itc-logistic.ro if unset.
NEXT_PUBLIC_SITE_URL=https://www.itc-logistic.ro

# The contact form currently opens the visitor's email client via a mailto:
# link — no backend or API key needed. If you later want silent in-page
# submission instead, wire ContactForm.tsx to an email API (e.g. Resend)
# and add its key here, e.g.:
# RESEND_API_KEY=
